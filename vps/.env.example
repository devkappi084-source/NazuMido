# Copy this file to .env and fill in the values
# Never commit .env to version control

# Port the server listens on (nginx proxies to this)
PORT=3000

# Secret API key — must match VPS_API_KEY in Cloudflare Pages env vars
API_KEY=change-me-long-random-string

# HMAC secret — must match HMAC_SECRET in Cloudflare Pages env vars
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
HMAC_SECRET=change-me-64-char-hex-string

# Absolute path where photos are stored on disk
PHOTOS_DIR=/var/www/nazumido/photos

# Your Cloudflare Pages domain (for CORS)
ALLOWED_ORIGIN=https://your-project.pages.dev
